(ns phel-test\test\cli
  (:require phel\cli :as cli)
  (:require phel\test :refer [deftest is]))

(defn- run-app [app args]
  (let [input  (cli/argv args)
        output (cli/buffered-output)
        code   (cli/run app input output)]
    {:code code :out (cli/output->string output)}))

(defn- run-cmd [cmd-spec args]
  (run-app (cli/application "test" [cmd-spec]) args))

(deftest test-run-simple-command
  (let [spec {:name "greet"
              :run  (fn [ctx] (cli/writeln ctx "hello"))}
        res  (run-cmd spec ["greet"])]
    (is (= 0 (get res :code)))
    (is (php/str_contains (get res :out) "hello"))))

(deftest test-command-with-argument
  (let [spec {:name "greet"
              :args [{:name "who" :mode :required}]
              :run  (fn [ctx] (cli/writeln ctx (str "hi " (cli/arg ctx "who"))))}
        res  (run-cmd spec ["greet" "alice"])]
    (is (= 0 (get res :code)))
    (is (php/str_contains (get res :out) "hi alice"))))

(deftest test-command-with-option
  (let [spec {:name "greet"
              :opts [{:name "loud" :mode :none :doc "SHOUT"}]
              :run  (fn [ctx]
                      (let [msg (if (cli/opt ctx "loud") "HELLO" "hello")]
                        (cli/writeln ctx msg)))}
        res  (run-cmd spec ["greet" "--loud"])]
    (is (= 0 (get res :code)))
    (is (php/str_contains (get res :out) "HELLO"))))

(deftest test-exit-code-propagates
  (let [spec {:name "fail"
              :run  (fn [_] 2)}
        res  (run-cmd spec ["fail"])]
    (is (= 2 (get res :code)))))

(deftest test-aliases
  (let [spec {:name "build" :aliases ["b" "compile"]
              :run  (fn [ctx] (cli/writeln ctx "built"))}
        res  (run-cmd spec ["b"])]
    (is (= 0 (get res :code)))
    (is (php/str_contains (get res :out) "built"))))

(deftest test-default-command
  (let [app (cli/application {:name "mytool"
                              :default "greet"
                              :commands [{:name "greet"
                                          :run (fn [ctx] (cli/writeln ctx "hola"))}]})
        res (run-app app [])]
    (is (= 0 (get res :code)))
    (is (php/str_contains (get res :out) "hola"))))

(deftest test-styled-info
  (let [spec {:name "say"
              :run  (fn [ctx] (cli/info ctx "ready"))}
        res  (run-cmd spec ["say"])]
    (is (php/str_contains (get res :out) "ready"))))

(deftest test-table
  (let [spec {:name "list"
              :run  (fn [ctx]
                      (cli/table ctx ["id" "name"] [[1 "alice"] [2 "bob"]]))}
        res  (run-cmd spec ["list"])]
    (is (= 0 (get res :code)))
    (is (php/str_contains (get res :out) "alice"))
    (is (php/str_contains (get res :out) "bob"))))
