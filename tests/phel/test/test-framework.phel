(ns phel-test\test\test-framework
  (:require phel\test :refer [deftest is testing get-stats reset-stats restore-stats do-report]))

;; Behavior coverage for the `is` macro and its built-in dispatch arms.
;;
;; These tests exercise the public surface of `phel\test/is` end-to-end:
;; pass paths run as ordinary `is` assertions, while fail/error paths use
;; the `get-stats`/`reset-stats`/`restore-stats` snapshot pattern so the
;; failure is observed in isolation without polluting the outer suite.
;; Output from the inner `is` is silenced via `with-output-buffer`.
;;
;; Each dispatch arm of the multimethod (`'not`, `'thrown?`,
;; `'thrown-with-msg?`, `'output?`, predicate, binary, and the
;; `:default` "any" form) is covered for both passing and failing inputs.

;; ---------------------------------------------------------------------------
;; 'not — predicate negation passes when inner is false
;; ---------------------------------------------------------------------------

(deftest test-is-not-predicate-passes-when-predicate-is-false
  (is (not (nil? 42)) "not nil? passes for non-nil value")
  (is (not (true? false)) "not true? passes for false")
  (is (not (false? true)) "not false? passes for true")
  (is (not (zero? 5)) "not zero? passes for non-zero")
  (is (not (empty? [1 2 3])) "not empty? passes for non-empty"))

(deftest test-is-not-predicate-fails-when-predicate-is-true
  (let [saved (get-stats)
        _ (reset-stats)
        _ (with-output-buffer (is (not (nil? nil))))
        counts (get (get-stats) :counts)]
    (restore-stats saved)
    (is (= 1 (:failed counts)) "not nil? on nil records a failure")
    (is (= 0 (:pass counts)) "no pass recorded")))

;; ---------------------------------------------------------------------------
;; 'not — binary negation passes when inner predicate is false
;; ---------------------------------------------------------------------------

(deftest test-is-not-binary-passes-when-predicate-is-false
  (is (not (= 1 2)) "not = passes for unequal values")
  (is (not (= :playing :lost)) "not = passes for different keywords")
  (is (not (< 5 3)) "not < passes when left is not less than right")
  (is (not (> 1 10)) "not > passes when left is not greater than right"))

(deftest test-is-not-binary-fails-when-predicate-is-true
  (let [saved (get-stats)
        _ (reset-stats)
        _ (with-output-buffer (is (not (= 1 1))))
        counts (get (get-stats) :counts)]
    (restore-stats saved)
    (is (= 1 (:failed counts)) "not (= 1 1) records a failure")))

;; ---------------------------------------------------------------------------
;; 'thrown? — passes when body throws the expected exception type
;; ---------------------------------------------------------------------------

(deftest test-is-thrown-passes-when-exception-type-matches
  (is (thrown? \InvalidArgumentException
               (throw (php/new \InvalidArgumentException "boom")))
      "thrown? passes when matching exception is thrown")
  (is (thrown? \Exception
               (throw (php/new \RuntimeException "boom")))
      "thrown? passes for subclass of expected exception"))

(deftest test-is-thrown-fails-when-no-exception-thrown
  (let [saved (get-stats)
        _ (reset-stats)
        _ (with-output-buffer
            (is (thrown? \InvalidArgumentException (+ 1 1))))
        counts (get (get-stats) :counts)]
    (restore-stats saved)
    (is (= 1 (:failed counts)) "thrown? without throw records a failure")))

;; ---------------------------------------------------------------------------
;; 'thrown-with-msg? — passes when body throws with the expected message
;; ---------------------------------------------------------------------------

(deftest test-is-thrown-with-msg-passes-when-message-matches
  (is (thrown-with-msg? \InvalidArgumentException "boom"
                        (throw (php/new \InvalidArgumentException "boom")))
      "thrown-with-msg? passes when message matches exactly"))

(deftest test-is-thrown-with-msg-fails-when-no-exception
  (let [saved (get-stats)
        _ (reset-stats)
        _ (with-output-buffer
            (is (thrown-with-msg? \InvalidArgumentException "boom" (+ 1 1))))
        counts (get (get-stats) :counts)]
    (restore-stats saved)
    (is (= 1 (:failed counts)) "thrown-with-msg? without throw records a failure")))

(deftest test-is-thrown-with-msg-fails-when-message-differs
  (let [saved (get-stats)
        _ (reset-stats)
        _ (with-output-buffer
            (is (thrown-with-msg? \InvalidArgumentException "expected"
                                  (throw (php/new \InvalidArgumentException "different")))))
        counts (get (get-stats) :counts)]
    (restore-stats saved)
    (is (= 1 (:failed counts)) "thrown-with-msg? with wrong message records a failure")))

;; ---------------------------------------------------------------------------
;; 'output? — passes when body's stdout matches the expected string
;; ---------------------------------------------------------------------------

(deftest test-is-output-passes-when-output-matches
  (is (output? "hello" (print "hello")) "output? passes when print emits expected text"))

(deftest test-is-output-fails-when-output-differs
  (let [saved (get-stats)
        _ (reset-stats)
        _ (with-output-buffer
            (is (output? "expected" (print "actual"))))
        counts (get (get-stats) :counts)]
    (restore-stats saved)
    (is (= 1 (:failed counts)) "output? mismatch records a failure")))

;; ---------------------------------------------------------------------------
;; :default — binary predicate (3-element list)
;; ---------------------------------------------------------------------------

(deftest test-is-binary-default-passes
  (is (= 4 (+ 2 2)) "= passes for equal values")
  (is (< 1 2) "< passes for ordered values")
  (is (> 10 5) "> passes for reverse-ordered values"))

(deftest test-is-binary-default-fails
  (let [saved (get-stats)
        _ (reset-stats)
        _ (with-output-buffer (is (= 1 2)))
        counts (get (get-stats) :counts)]
    (restore-stats saved)
    (is (= 1 (:failed counts)) "= on unequal values records a failure")))

;; ---------------------------------------------------------------------------
;; :default — unary predicate (2-element list)
;; ---------------------------------------------------------------------------

(deftest test-is-predicate-default-passes
  (is (nil? nil) "nil? passes for nil")
  (is (true? true) "true? passes for true")
  (is (zero? 0) "zero? passes for zero"))

(deftest test-is-predicate-default-fails
  (let [saved (get-stats)
        _ (reset-stats)
        _ (with-output-buffer (is (nil? 1)))
        counts (get (get-stats) :counts)]
    (restore-stats saved)
    (is (= 1 (:failed counts)) "nil? on non-nil records a failure")))

;; ---------------------------------------------------------------------------
;; :default — "any" arm (4+ element lists fall through to assert-any)
;; ---------------------------------------------------------------------------

(deftest test-is-any-passes-for-truthy-list-result
  (is (and true 1 2 3) "and of truthy values evaluates to truthy")
  (is (or false nil 42 :unused) "or returns first truthy value"))

(deftest test-is-any-fails-when-list-result-is-falsy
  (let [saved (get-stats)
        _ (reset-stats)
        _ (with-output-buffer (is (and true false 1 2)))
        _ (with-output-buffer (is (or false nil false nil)))
        counts (get (get-stats) :counts)]
    (restore-stats saved)
    (is (= 2 (:failed counts)) "falsy and/or expressions both record failures")))

;; ---------------------------------------------------------------------------
;; Error path — `is` catches exceptions raised by the assertion body and
;; reports them as :error (distinct from :failed).
;; ---------------------------------------------------------------------------

(deftest test-is-records-error-when-body-throws
  (let [saved (get-stats)
        _ (reset-stats)
        _ (with-output-buffer
            (is (= 1 (throw (php/new \RuntimeException "boom inside is")))))
        counts (get (get-stats) :counts)]
    (restore-stats saved)
    (is (= 1 (:error counts)) "uncaught exception in assertion is reported as :error")
    (is (= 0 (:failed counts)) "not counted as a failure")))

;; ---------------------------------------------------------------------------
;; Stats accounting — pass increments :pass and :total without touching :failed
;; ---------------------------------------------------------------------------

(deftest test-passing-assertion-increments-pass-and-total-only
  (let [saved (get-stats)
        _ (reset-stats)
        _ (with-output-buffer (is (= 1 1)))
        counts (get (get-stats) :counts)]
    (restore-stats saved)
    (is (= 1 (:pass counts)) "pass count incremented")
    (is (= 0 (:failed counts)) "failed count untouched")
    (is (= 0 (:error counts)) "error count untouched")
    (is (= 1 (:total counts)) "total incremented")))

;; ---------------------------------------------------------------------------
;; Stats accounting — failing assertion captures the failure data
;; ---------------------------------------------------------------------------

(deftest test-failing-assertion-records-failure-data
  (let [saved (get-stats)
        _ (reset-stats)
        _ (with-output-buffer (is (= 1 2) "intentional failure"))
        snapshot (get-stats)]
    (restore-stats saved)
    (is (= 1 (count (get snapshot :failed))) "one failure recorded in :failed list")
    (let [failure (first (get snapshot :failed))]
      (is (= "intentional failure" (get failure :message))
          "failure preserves the user-provided message"))))

;; ---------------------------------------------------------------------------
;; testing macro — context wrapper for grouping assertions
;; ---------------------------------------------------------------------------

(deftest test-testing-executes-body
  (testing "arithmetic"
    (is (= 4 (+ 2 2)) "testing macro executes body assertions")))

(deftest test-testing-nested
  (testing "outer"
    (testing "inner"
      (is (= 1 1) "nested testing blocks execute"))))

(deftest test-testing-context-in-failure-message
  (let [saved (get-stats)
        _ (reset-stats)
        _ (with-output-buffer
            (testing "math basics"
              (is (= 1 2) "addition")))
        snapshot (get-stats)]
    (restore-stats saved)
    (let [failure (first (get snapshot :failed))]
      (is (= "math basics - addition" (get failure :message))
          "testing context is prepended to failure message"))))

;; ---------------------------------------------------------------------------
;; do-report — Clojure-compatible entry point that delegates to report
;; ---------------------------------------------------------------------------

(deftest test-do-report-pass-increments-pass-count
  (let [saved (get-stats)
        _ (reset-stats)
        _ (with-output-buffer (do-report {:state :pass :type :any :message "ok"}))
        counts (get (get-stats) :counts)]
    (restore-stats saved)
    (is (= 1 (:pass counts)) "do-report with :pass increments pass count")
    (is (= 1 (:total counts)) "do-report with :pass increments total")
    (is (= 0 (:failed counts)) "do-report with :pass does not increment failed")))

(deftest test-do-report-failure-records-failure
  (let [saved (get-stats)
        _ (reset-stats)
        _ (with-output-buffer (do-report {:state :failed :type :any :message "nope"}))
        snapshot (get-stats)]
    (restore-stats saved)
    (is (= 1 (:failed (get snapshot :counts))) "do-report with :failed increments failed count")
    (is (= 1 (count (get snapshot :failed))) "do-report with :failed records failure data")
    (let [failure (first (get snapshot :failed))]
      (is (= "nope" (get failure :message)) "do-report preserves message"))))

(deftest test-do-report-preserves-location
  (let [saved (get-stats)
        loc {:file "test.phel" :line 42 :column 1}
        _ (reset-stats)
        _ (with-output-buffer (do-report {:state :failed :type :any :location loc}))
        snapshot (get-stats)]
    (restore-stats saved)
    (let [failure (first (get snapshot :failed))]
      (is (= loc (get failure :location)) "do-report preserves :location in result"))))

(deftest test-do-report-works-without-location
  (let [saved (get-stats)
        _ (reset-stats)
        _ (with-output-buffer (do-report {:state :pass :type :any}))
        counts (get (get-stats) :counts)]
    (restore-stats saved)
    (is (= 1 (:pass counts)) "do-report works without :location key")))
