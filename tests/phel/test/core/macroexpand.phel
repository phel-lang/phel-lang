(ns phel-test\test\core\macroexpand
  (:require phel\test :refer [deftest is]))

(deftest test-macroexpand-1-when
  (is (= '(if true (do 1 2))
         (macroexpand-1 '(when true 1 2)))))

(deftest test-macroexpand-threading
  (is (= '(+ 1 2)
         (macroexpand '(-> 1 (+ 2))))))

(deftest test-macroexpand-inline
  (is (= '(inc 1)
         (macroexpand-1 '(inc 1)))))
