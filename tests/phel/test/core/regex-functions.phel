(ns phel-test\test\core\regex-functions
  (:require phel\test :refer [deftest is]))

(deftest test-re-seq
  (let [input "Hello, 1 regex 2 test"]
    (is (= ["1" "2"] (re-seq "/\d+/" input)) "regex [0-9]")
    (is (= ["Hello" "1" "regex" "2" "test"] (re-seq "/\w+/" input)) "regex [a-zA-Z0-9_]")))

(deftest test-re-seq-doesnt-match
  (let [input "Hello, one regex two test"]
    (is (= [] (re-seq "/\d+/" input)) "regex [0-9] doesn't match")))

(deftest test-re-seq-with-capture
  (let [input "one=1 two=2 none="
        expected [["one=1" "one" "1"]
                  ["two=2" "two" "2"]
                  ["none=" "none" ""]]]
    (is (= expected (re-seq "/(\w+)=(\w*)/" input)) "regex with capture")))

(deftest test-re-seq-with-capture-doesnt-match
  (let [input "one,1 two,2 none,"]
    (is (= [] (re-seq "/(\w+)=(\w*)/" input)) "regex with capture doesn't match")))

;; --- re-find ---

(deftest test-re-find
  (is (= "123" (re-find "/\\d+/" "abc123def")) "re-find returns first match")
  (is (nil? (re-find "/\\d+/" "abcdef")) "re-find returns nil on no match"))

(deftest test-re-find-with-groups
  (is (= ["12-34" "12" "34"] (re-find "/(\\d+)-(\\d+)/" "abc12-34def"))
      "re-find with groups returns vector"))

;; --- re-matches ---

(deftest test-re-matches
  (is (= "12345" (re-matches "/\\d+/" "12345")) "re-matches full string")
  (is (nil? (re-matches "/\\d+/" "abc123")) "re-matches requires full string match"))

(deftest test-re-matches-with-groups
  (is (= ["12-34" "12" "34"] (re-matches "/(\\d+)-(\\d+)/" "12-34"))
      "re-matches with groups"))
