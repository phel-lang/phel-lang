--PHEL--
(def x 1.5M)
--PHP--
\Phel::addDefinition(
  "user",
  "x",
  \Phel\Lang\BigDecimal::fromString("1.5"),
  \Phel::map(
    \Phel\Lang\Keyword::create("start-location"), \Phel::location("Def/bigdec-literal.test", 1, 0),
    \Phel\Lang\Keyword::create("end-location"), \Phel::location("Def/bigdec-literal.test", 1, 12)
  )
);
