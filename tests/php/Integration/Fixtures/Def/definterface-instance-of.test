--PHEL--
(ns interface-instance)

(definterface IPlayer
  (choose [p] "Choose docs")
  (update-strategy [p me you]))

(php/instanceof "foo" IPlayer)
--PHP--
namespace interface_instance;
require_once __DIR__ . '/phel/core.php';
\Phel::addDefinition(
  "phel.core",
  "*file*",
  "Def/definterface-instance-of.test"
);
\Phel::addDefinition(
  "phel.core",
  "*ns*",
  "interface-instance"
);
if (!interface_exists('interface_instance\IPlayer')) {
interface IPlayer {
  public function choose();
  public function update_strategy($me, $you);
}
}

\Phel::addDefinition(
  "interface_instance",
  "choose",
  new class() extends \Phel\Lang\AbstractFn {
    public const BOUND_TO = "interface_instance\\choose";

    public function __invoke($p) {
      if ((is_a($p, "interface_instance\\IPlayer"))) {
        return ($p->choose());
      } else {
        throw (new \InvalidArgumentException("Value doesn't implement interface IPlayer"));
      }

    }
  },
  \Phel::map(
    \Phel\Lang\Keyword::create("doc"), "```phel\n(choose p)\n```\nChoose docs",
    \Phel\Lang\Keyword::create("start-location"), \Phel::location("Def/definterface-instance-of.test", 3, 0),
    \Phel\Lang\Keyword::create("end-location"), \Phel::location("Def/definterface-instance-of.test", 5, 31),
    "min-arity", 1,
    "is-variadic", false,
    "arglists", "[p]"
  )
);

\Phel::addDefinition(
  "interface_instance",
  "update-strategy",
  new class() extends \Phel\Lang\AbstractFn {
    public const BOUND_TO = "interface_instance\\update_strategy";

    public function __invoke($p, $me, $you) {
      if ((is_a($p, "interface_instance\\IPlayer"))) {
        return (function() use($p,$me,$you) {
          $target_1 = $p;
          return $target_1->update_strategy($me, $you);
        })();
      } else {
        throw (new \InvalidArgumentException("Value doesn't implement interface IPlayer"));
      }

    }
  },
  \Phel::map(
    \Phel\Lang\Keyword::create("doc"), "```phel\n(update-strategy p me you)\n```\n",
    \Phel\Lang\Keyword::create("start-location"), \Phel::location("Def/definterface-instance-of.test", 3, 0),
    \Phel\Lang\Keyword::create("end-location"), \Phel::location("Def/definterface-instance-of.test", 5, 31),
    "min-arity", 3,
    "is-variadic", false,
    "arglists", "[p me you]"
  )
);
("foo" instanceof \interface_instance\IPlayer);
