--PHEL--
(def x "my number" 1)
--PHP--
\Phel::addDefinition(
  "user",
  "x",
  1,
  \Phel::map(
    \Phel::keyword("doc"), "my number",
    \Phel::keyword("start-location"), \Phel::location("Def/doc-def.test", 1, 0),
    \Phel::keyword("end-location"), \Phel::location("Def/doc-def.test", 1, 21)
  )
);
