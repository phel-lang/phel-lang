--PHEL--
(def make-foo
  (fn []
    (defstruct* foo-inside [a])))
--PHP--
\Phel::addDefinition(
  "user",
  "make-foo",
  new class() extends \Phel\Lang\AbstractFn {
    public const BOUND_TO = "user\\make_foo";

    public function __invoke() {
      if (!class_exists('user\foo_inside')) {
        eval('namespace user;
      final class foo_inside extends \\Phel\\Lang\\Collections\\Struct\\AbstractPersistentStruct {

        protected const array ALLOWED_KEYS = [\'a\'];

        protected $a;

        public function __construct($a, $meta = null) {
          parent::__construct();
          $this->a = $a;
          $this->meta = $meta;
        }
      }
');
      }

    }
  },
  \Phel::map(
    \Phel\Lang\Keyword::create("start-location"), \Phel::location("Def/defstruct-inside-fn-body.test", 1, 0),
    \Phel\Lang\Keyword::create("end-location"), \Phel::location("Def/defstruct-inside-fn-body.test", 3, 33),
    "min-arity", 0,
    "is-variadic", false,
    "arglists", "[]"
  )
);
