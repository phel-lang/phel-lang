--PHEL--
(ns my\ns)

(def x 1)
--PHP--
namespace my\ns;
require_once __DIR__ . '/../phel/core.php';
\Phel::addDefinition(
  "phel.core",
  "*file*",
  "Def/namespace-def.test"
);
\Phel::addDefinition(
  "phel.core",
  "*ns*",
  "my.ns"
);
\Phel::addDefinition(
  "my.ns",
  "x",
  1,
  \Phel::map(
    \Phel\Lang\Keyword::create("start-location"), \Phel::location("Def/namespace-def.test", 3, 0),
    \Phel\Lang\Keyword::create("end-location"), \Phel::location("Def/namespace-def.test", 3, 9)
  )
);
