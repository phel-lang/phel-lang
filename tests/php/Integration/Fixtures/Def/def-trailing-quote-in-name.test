--PHEL--
(def a' 42)
--PHP--
\Phel::addDefinition(
  "user",
  "a\'",
  42,
  \Phel::map(
    \Phel::keyword("start-location"), \Phel::map(
      \Phel::keyword("file"), "Def/def-trailing-quote-in-name.test",
      \Phel::keyword("line"), 1,
      \Phel::keyword("column"), 0
    ),
    \Phel::keyword("end-location"), \Phel::map(
      \Phel::keyword("file"), "Def/def-trailing-quote-in-name.test",
      \Phel::keyword("line"), 1,
      \Phel::keyword("column"), 11
    )
  )
);
