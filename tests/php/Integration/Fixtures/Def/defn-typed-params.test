--PHEL--
(defn add [^{:tag "int"} x ^{:tag "int"} y] (php/+ x y))
--PHP--
\Phel::addDefinition(
  "user",
  "add",
  new class() extends \Phel\Lang\AbstractFn {
    public const BOUND_TO = "user\\add";

    public function __invoke(int $x, int $y): int {
      return ($x + $y);
    }
  },
  \Phel::locationMeta(
    \Phel::location("Def/defn-typed-params.test", 1, 0),
    \Phel::location("Def/defn-typed-params.test", 1, 56),
    \Phel\Lang\Keyword::create("doc"), "```phel\n(add x y)\n```\n",
    "min-arity", 2,
    "is-variadic", false,
    "arglists", "[x y]",
    \Phel\Lang\Keyword::create("tag"), "int"
  )
);
