--PHEL--
(defonce counter 0)
--PHP--
if (!\Phel::isDefined("user", "counter")) {
  \Phel::addDefinition(
    "user",
    "counter",
    0,
    \Phel::map(
      \Phel\Lang\Keyword::create("start-location"), \Phel::location("Def/defonce.test", 1, 0),
      \Phel\Lang\Keyword::create("end-location"), \Phel::location("Def/defonce.test", 1, 19)
    )
  );
}
