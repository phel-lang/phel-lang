--PHEL--
(def x 1)
(set-var x 2)
--PHP--
\Phel::addDefinition(
  "user",
  "x",
  1,
  \Phel::map(
    \Phel\Lang\Keyword::create("start-location"), \Phel::location("SetVar/set-var.test", 1, 0),
    \Phel\Lang\Keyword::create("end-location"), \Phel::location("SetVar/set-var.test", 1, 9)
  )
);
\Phel::setVar(
  "user",
  "x",
  2
);
