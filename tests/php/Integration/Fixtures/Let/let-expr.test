--PHEL--
(def x (let [x 1 y 2] (php/+ x y)))
--PHP--
\Phel::addDefinition(
  "user",
  "x",
  (function() {
    /** @var int $x_1 */
    $x_1 = 1;
    /** @var int $y_2 */
    $y_2 = 2;
    return ($x_1 + $y_2);
  })(),
  \Phel::locationMeta(\Phel::location("Let/let-expr.test", 1, 0), \Phel::location("Let/let-expr.test", 1, 35))
);
