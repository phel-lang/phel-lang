--PHEL--
(loop [n 10
       sum 0]
  (if (php/<= n 0) sum (recur (php/- n 1) (php/+ sum n))))
--PHP--
/** @var int $n_1 */
$n_1 = 10;
/** @var int $sum_2 */
$sum_2 = 0;
while (true) {
  if ((($n_1 <= 0))) {
    $sum_2;
  } else {
    $__phel_3 = ($n_1 - 1);
    $__phel_4 = ($sum_2 + $n_1);
    $n_1 = $__phel_3;
    $sum_2 = $__phel_4;
    continue;

  }
  break;
}
