--PHEL--
(fn []
  (let [b 10]
    (foreach [b [1 2 3]]
      (println b))))
--PHP--
(function() {
  $b_1 = 10;
  return (function() use($b_1) {
    foreach (\Phel\Lang\Seq::toIterable(\Phel::vector([1, 2, 3])) as $b) {
      (\Phel::getDefinition("phel\\core", "println"))($b);
    }
    return null;
  })();
});
