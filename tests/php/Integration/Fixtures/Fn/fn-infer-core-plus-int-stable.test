--PHEL--
(defn add-pair [x y] (php/random_int 0 (+ x y)))
--PHP--
\Phel::addDefinition(
  "user",
  "add-pair",
  new class() extends \Phel\Lang\AbstractFn {
    public const BOUND_TO = "user\\add_pair";

    public function __invoke(int $x, int $y): int {
      return random_int(0, ($x + $y));
    }
  },
  \Phel::locationMeta(
    \Phel::location("Fn/fn-infer-core-plus-int-stable.test", 1, 0),
    \Phel::location("Fn/fn-infer-core-plus-int-stable.test", 1, 48),
