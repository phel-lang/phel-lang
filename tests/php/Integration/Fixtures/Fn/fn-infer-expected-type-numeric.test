--PHEL--
(defn rrange [lo hi] (php/random_int 0 (php/- hi lo)))
--PHP--
\Phel::addDefinition(
  "user",
  "rrange",
  new class() extends \Phel\Lang\AbstractFn {
    public const BOUND_TO = "user\\rrange";

    public function __invoke(int $lo, int $hi): int {
      return random_int(0, ($hi - $lo));
    }
  },
  \Phel::map(
    \Phel::keyword("doc"), "```phel\n(rrange lo hi)\n```\n",
    \Phel::keyword("start-location"), \Phel::location("Fn/fn-infer-expected-type-numeric.test", 1, 0),
    \Phel::keyword("end-location"), \Phel::location("Fn/fn-infer-expected-type-numeric.test", 1, 54),
    "min-arity", 2,
    "is-variadic", false,
    "arglists", "[lo hi]",
    \Phel::keyword("tag"), "int"
  )
);
