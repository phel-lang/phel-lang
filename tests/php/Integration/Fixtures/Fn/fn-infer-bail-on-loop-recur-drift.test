--PHEL--
(fn [^int n]
  (loop [acc n]
    (if (php/<= acc 1) acc (recur (php/. "x" acc)))))
--PHP--
(function(int $n) {
  $acc_1 = $n;
  while (true) {
    if (($__truthy = ($acc_1 <= 1)) !== null && $__truthy !== false) {
      return $acc_1;
    } else {
      $__phel_2 = ("x" . $acc_1);
      $acc_1 = $__phel_2;
      continue;

    }
    break;
  }
});
