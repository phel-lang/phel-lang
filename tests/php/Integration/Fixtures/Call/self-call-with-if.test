    ),
    \Phel::keyword("end-location"), \Phel::map(
      \Phel::keyword("file"), "Call/self-call-with-if.test",
      \Phel::keyword("line"), 1,
      \Phel::keyword("column"), 52
    ),
    "min-arity", 1,
    "is-variadic", false,
    "arglists", "[n]"
  )
);
