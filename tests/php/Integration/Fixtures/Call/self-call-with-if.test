--PHEL--
(defn rec [n] (if (php/== n 0) n (rec (php/- n 1))))
--PHP--
\Phel::addDefinition(
  "user",
  "rec",
  new class() extends \Phel\Lang\AbstractFn {
    public const BOUND_TO = "user\\rec";

    public function __invoke(int $n) {
      if ((($n == 0))) {
        return $n;
      } else {
        return $this(($n - 1));
      }

    }
  },
  \Phel::map(
    \Phel::keyword("doc"), "```phel\n(rec n)\n```\n",
    \Phel::keyword("start-location"), \Phel::location("Call/self-call-with-if.test", 1, 0),
    \Phel::keyword("end-location"), \Phel::location("Call/self-call-with-if.test", 1, 52),
    "min-arity", 1,
    "is-variadic", false,
    "arglists", "[n]"
  )
);
