    ),
    \Phel::keyword("end-location"), \Phel::map(
      \Phel::keyword("file"), "VarQuote/var-special-form.test",
      \Phel::keyword("line"), 1,
      \Phel::keyword("column"), 9
    )
  )
);
Phel\Lang\Registry::getInstance()->getVar("user", "x");
