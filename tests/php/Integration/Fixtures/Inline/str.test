--PHEL--
(fn [^string a] (str))
(fn [^string a] (str a))
(fn [^string a ^string b] (str a b))
(fn [^string a ^string b ^string c] (str a b c))
--PHP--
(function(string $a) {
  return "";
});(function(string $a): string {
  return ($a);
});(function(string $a, string $b): string {
  return ($a . $b);
});(function(string $a, string $b, string $c): string {
  return ($a . $b . $c);
});
