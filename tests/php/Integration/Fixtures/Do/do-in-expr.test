--PHEL--
(def x (do (php/+ 1 2) (php/+ 3 4)))
--PHP--
\Phel::addDefinition(
  "user",
  "x",
  (function() {
    (1 + 2);
    return (3 + 4);
  })(),
  \Phel::map(
    \Phel\Lang\Keyword::create("start-location"), \Phel::location("Do/do-in-expr.test", 1, 0),
    \Phel\Lang\Keyword::create("end-location"), \Phel::location("Do/do-in-expr.test", 1, 36)
  )
);
