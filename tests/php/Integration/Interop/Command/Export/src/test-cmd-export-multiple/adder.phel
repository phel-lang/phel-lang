(ns test-cmd-export-multiple\adder)

(defn adder-1
  {:export true}
  [a b]
  (php/+ a b))

(defn adder-2
  {:export true}
  [a b]
  (php/+ a b))

(defn adder-3
  {:export true
   :php/attr [[:My.Routing/Route "/add"]]}
  [a b]
  (php/+ a b))

(defn ^int typed-adder
  {:export true}
  [^int a ^int b]
  (php/+ a b))

(defn ^int multi-adder
  {:export true}
  ([^int a] a)
  ([^int a ^int b] (php/+ a b)))
