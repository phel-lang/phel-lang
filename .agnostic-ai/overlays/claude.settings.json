{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(composer *)",
      "Bash(./bin/phel *)",
      "Bash(./vendor/bin/*)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(timeout *)",
      "Bash(ls *)",
      "Bash(wc *)",
      "Bash(rm -rf /tmp/phel)",
      "Bash(rm -rf /tmp/phel/*)",
      "Bash(rm -rf data/cache)",
      "Bash(rm -rf data/cache/*)",
      "Bash(rm -rf /tmp/phel data/cache)"
    ],
    "deny": [
      "Bash(rm -rf /:*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf $HOME*)",
      "Bash(rm -rf ..*)",
      "Bash(rm -fr /:*)",
      "Bash(sudo:*)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)",
      "Bash(mkfs:*)"
    ]
  },
  "hooks": null,
  "statusLine": {
    "type": "command",
    "command": "/bin/bash .agnostic-ai/scripts/claude/statusline.sh"
  }
}
