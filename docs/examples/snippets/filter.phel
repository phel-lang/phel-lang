(ns examples\snippets\filter)

(println (filter pos? [1 -2 3 0 -4 5]))   ; @[1 3 5]
(println (filter even? (range 10)))       ; @[0 2 4 6 8]

(println (filter |(> (count $) 3)
                 ["hi" "hello" "yo" "world"])) ; @["hello" "world"]

;; Inverse: remove
(println (remove even? (range 6)))         ; @[1 3 5]
