(ns examples\snippets\loop-recur)

;; Factorial with loop/recur (constant stack)
(defn fact [n]
  (loop [i n acc 1]
    (if (<= i 1) acc (recur (dec i) (* acc i)))))

(println (fact 5))                         ; 120
(println (fact 10))                        ; 3628800

;; Sum a vector
(defn sum [xs]
  (loop [xs xs total 0]
    (if (empty? xs) total
        (recur (rest xs) (+ total (first xs))))))

(println (sum [1 2 3 4 5]))                ; 15
