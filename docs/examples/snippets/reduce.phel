(ns examples\snippets\reduce)

(println (reduce + [1 2 3 4 5]))           ; 15
(println (reduce + 100 [1 2 3]))           ; 106
(println (reduce max [3 1 4 1 5 9 2 6]))   ; 9

;; Build a map by reducing
(println (reduce (fn [m k] (assoc m k (* k k)))
                 {} [1 2 3]))              ; {1 1 2 4 3 9}
