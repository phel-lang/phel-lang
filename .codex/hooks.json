{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": ".codex/hooks/session-context.sh",
            "timeout": 5,
            "statusMessage": "Loading Phel repository context"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".codex/hooks/protect-files.sh",
            "timeout": 5,
            "statusMessage": "Checking protected files"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".codex/hooks/format-php.sh",
            "timeout": 30,
            "statusMessage": "Formatting touched PHP files"
          }
        ]
      }
    ]
  }
}
